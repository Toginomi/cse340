<div class="vehicle-detail">
    <!-- Display the vehicle title (make and model) -->
    <h1><%= title %></h1>

    <!-- Display vehicle image if available -->
    <% if (vehicleGrid.image_url) { %>
        <img src="<%= vehicleGrid.image_url %>" alt="<%= title %> image" class="vehicle-image">
    <% } else { %>
        <p>No image available</p>
    <% } %>
    
    <div class="vehicle-info">
      <ul>
          <li><strong>Make:</strong> <%= vehicleGrid.inv_make %></li>
          <li><strong>Model:</strong> <%= vehicleGrid.inv_model %></li>
          <li><strong>Year:</strong> <%= vehicleGrid.inv_year %></li>
          <li><strong>Color:</strong> <%= vehicleGrid.inv_color %></li>
          <li><strong>Price:</strong> $<%= vehicleGrid.inv_price %></li>
          <li><strong>Mileage:</strong> <%= vehicleGrid.inv_mileage %> miles</li>
          <li><strong>Transmission:</strong> <%= vehicleGrid.inv_transmission %></li>
          <li><strong>Engine Size:</strong> <%= vehicleGrid.inv_engine_size %></li>
          <li><strong>Fuel Type:</strong> <%= vehicleGrid.inv_fuel_type %></li>
          <li><strong>VIN Number:</strong> <%= vehicleGrid.inv_vin_number %></li>
      </ul>
  </div>

    <% if (vehicleGrid.inv_description) { %>
        <div class="vehicle-description">
            <h2>Description:</h2>
            <p><%= vehicleGrid.inv_description %></p>
        </div>
    <% } %>

    <a href="/type/<%= vehicleGrid.classification_id %>" class="back-to-list">Back to Classification</a>
</div>
